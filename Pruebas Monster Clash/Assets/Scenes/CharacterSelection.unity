      m_Calls: []
  m_text: "<b>ISA EL PEQUE\xD1O GUERRERO ONI:</b>\n\nPrincipe heredero del trono
    azul, ultimo de los clanes Oni, conocidos por su capacidad para el sigilo. Harto
    de esconderse, el peque\xF1o guerrero decidio emprender un viaje para demostrar
    que su gente pueden ser mas que \u201Ccobardes\u201D. Volvera a casa una vez
    haya logrado algo realmente impresionante."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 102485f4736b4dc4fb6ff8d8b9317f3f, type: 2}
